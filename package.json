{
  "name": "@hyperttp/core",
  "version": "1.2.6",
  "description": "High-performance, extensible HTTP client for Node.js and Bun and other",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "http",
    "client",
    "high-performance",
    "undici",
    "fetch",
    "bun"
  ],
  "author": "dirold2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IT-IF-OR/hyperttp-core.git"
  },
  "peerDependencies": {
    "@hyperttp/transport-bun": "^0.1.5",
    "@hyperttp/transport-undici": "^0.1.7"
  },
  "peerDependenciesMeta": {
    "@hyperttp/transport-bun": {
      "optional": true
    },
    "@hyperttp/transport-undici": {
      "optional": true
    }
  },
  "private": false
}