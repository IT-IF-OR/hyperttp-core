{
  "name": "@hyperttp/core",
  "version": "1.5.0",
  "description": "High-performance, extensible HTTP client for Node.js, Bun, Deno and Browser",
  "type": "module",
  "sideEffects": false,
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    }
  },
  "keywords": [
    "http",
    "client",
    "high-performance",
    "undici",
    "fetch",
    "bun",
    "deno",
    "isomorphic",
    "hyperttp"
  ],
  "author": "dirold2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IT-IF-OR/hyperttp-core.git"
  },
  "peerDependencies": {
    "@hyperttp/types": "^0.2.4",
    "@hyperttp/transport-bun": "^0.2.3",
    "@hyperttp/transport-undici": "^0.2.3"
  },
  "peerDependenciesMeta": {
    "@hyperttp/types": {
      "optional": false
    },
    "@hyperttp/transport-bun": {
      "optional": true
    },
    "@hyperttp/transport-undici": {
      "optional": true
    }
  },
  "private": false
}