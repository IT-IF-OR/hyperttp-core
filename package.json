{
  "name": "@hyperttp/core",
  "version": "1.4.5",
  "description": "High-performance, extensible HTTP client for Node.js, Bun, Deno and Browser",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "http",
    "client",
    "high-performance",
    "undici",
    "fetch",
    "bun",
    "deno",
    "isomorphic",
    "hyperttp"
  ],
  "author": "dirold2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IT-IF-OR/hyperttp-core.git"
  },
  "peerDependencies": {
    "@hyperttp/types": "^0.2.1",
    "@hyperttp/transport-bun": "^0.2.2",
    "@hyperttp/transport-undici": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@hyperttp/types": {
      "optional": false
    },
    "@hyperttp/transport-bun": {
      "optional": true
    },
    "@hyperttp/transport-undici": {
      "optional": true
    }
  },
  "dependencies": {
    "resolve-from": "^5.0.0"
  },
  "devDependencies": {
    "@dirold2/dev-tools": "^1.0.16",
    "@types/bun": "^1.3.14",
    "@types/deno": "^2.7.0",
    "@types/node": "^25.9.3",
    "@types/resolve-from": "^5.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "chalk": "^5.6.2",
    "dotenv-cli": "^11.0.0",
    "jiti": "^2.7.0",
    "oxlint": "^1.69.0",
    "oxfmt": "^0.54.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "build": "tsc && d-build",
    "dist": "d-dist",
    "deploy": "npm run build && npm run dist",
    "publish": "d-publish",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "format:check": "oxfmt src --check",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  }
}
