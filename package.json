{
  "name": "@hyperttp/core",
  "version": "1.1.6",
  "description": "High-performance, extensible HTTP client for Node.js and Bun",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "http",
    "client",
    "high-performance",
    "undici",
    "fetch",
    "bun"
  ],
  "author": "dirold2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IT-IF-OR/hyperttp-core.git"
  },
  "peerDependencies": {
    "typescript": "^6",
    "undici": "^8.3.0"
  },
  "dependencies": {
    "http-cookie-agent": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "@types/bun": "^1.3.14",
    "chalk": "^5.6.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "3.8.3",
    "jiti": "^2.7.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7",
    "@dirold2/dev-tools": "^1.0.12"
  },
  "scripts": {
    "build": "tsc && d-build",
    "dist": "d-dist",
    "deploy": "npm run build && npm run dist",
    "publish": "d-publish",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "format": "prettier --write .",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  }
}
